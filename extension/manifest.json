{
  "manifest_version": 3,
  "name": "SocialPhishing Detector",
  "version": "1.0.0",
  "description": "Detects phishing links on any webpage using machine learning. Links are colour-coded: green = Safe, amber = Suspicious, red = Phishing.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://socialphishing-api.onrender.com/*",
    "https://*/*",
    "http://*/*"
  ],

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "SocialPhishing Detector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
